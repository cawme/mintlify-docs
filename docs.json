{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "appearance": "light",
  "name": "Cawme",
  "colors": {
    "primary": "#25D366",
    "light": "#128C7E",
    "dark": "#075E54"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "guides/authentication",
              "guides/instances",
              "guides/call-types"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Instances",
            "pages": [
              "api-reference/instances/create",
              "api-reference/instances/list",
              "api-reference/instances/get",
              "api-reference/instances/delete",
              "api-reference/instances/configure"
            ]
          },
          {
            "group": "Calls",
            "pages": [
              "api-reference/calls/create",
              "api-reference/calls/get",
              "api-reference/calls/terminate",
              "api-reference/calls/stream"
            ]
          },
          {
            "group": "Leads",
            "pages": ["api-reference/leads/create"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "href": "mailto:support@cawme.com.br",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@cawme.com.br"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://cawme.com.br/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/cawme.br"
    }
  }
}
